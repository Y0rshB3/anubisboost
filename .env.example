# =============================================================================
# AnubisBoost Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# General
NODE_ENV=development
APP_NAME=anubisboost
APP_PORT=3000

# Frontend (Vite)
VITE_PORT=5173

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=anubisboost
MYSQL_USER=anubisboost
MYSQL_PASSWORD=changeme_dev_only
MYSQL_ROOT_PASSWORD=changeme_root_dev_only

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=replace-with-64-char-random-string-for-access-tokens
JWT_REFRESH_SECRET=replace-with-another-64-char-random-string
JWT_EXPIRY=15m

# AES Encryption (for game credentials)
AES_SECRET_KEY=replace-with-64-hex-chars-for-aes-256-key

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Email (Nodemailer) - optional for dev
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="AnubisBoost <noreply@anubisboost.com>"

# Production Only
# DOMAIN=anubisboost.example.com
# SSL_EMAIL=admin@example.com
# FRONTEND_URL=https://anubisboost.example.com
